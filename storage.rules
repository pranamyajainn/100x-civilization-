rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        firestore.get(/databases/ai-studio-2528f7ed-584f-4acd-b0fb-b766dcc4cbcf/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }

    match /certificates/{uid}/{fileName} {
      allow create: if isOwner(uid) &&
                       request.resource.size <= 5 * 1024 * 1024 &&
                       request.resource.contentType.matches('(application/pdf|image/jpeg|image/png)');
      allow read: if isOwner(uid) || isAdmin();
      allow update, delete: if false;
    }

  }
}
