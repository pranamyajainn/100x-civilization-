rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isApproved() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    function clientWritableUserFields() {
      return [
        'fullName',
        'email',
        'phone',
        'cohort',
        'linkedinUrl',
        'skillTags',
        'availability',
        'contactVisible',
        'notificationsEnabled',
        'certificateUrl',
        'verificationMethod',
        'consentGiven',
        'hiddenFromFeed',
        'embedding',
        'currentRole',
      ];
    }

    function protectedUserFields() {
      return ['isAdmin', 'status', 'onboardingComplete', 'verificationStatus'];
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /metadata/{docId} {
      allow read: if true;
      allow update: if request.resource.data.keys().hasOnly(['count']) &&
                       request.resource.data.count is number;
      allow create: if false;
    }

    match /waitlist_signups/{signupId} {
      allow read: if false;
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasAny(['fullName', 'email', 'cohort', 'role', 'createdAt']) &&
        request.resource.data.fullName is string && request.resource.data.fullName.size() >= 2 && request.resource.data.fullName.size() <= 80 &&
        request.resource.data.email is string && request.resource.data.email.matches('^.+@.+\\.[a-zA-Z]+$') && request.resource.data.email.size() <= 100 &&
        request.resource.data.cohort is string &&
        request.resource.data.role is string &&
        (
          !('referral' in request.resource.data) ||
          (request.resource.data.referral is string && request.resource.data.referral.size() <= 200)
        ) &&
        (
          !('linkedin' in request.resource.data) ||
          (request.resource.data.linkedin is string && request.resource.data.linkedin.size() <= 200)
        ) &&
        (
          !('position' in request.resource.data) ||
          (request.resource.data.position is number)
        ) &&
        (
          !('referralCode' in request.resource.data) ||
          (request.resource.data.referralCode is string)
        ) &&
        request.resource.data.createdAt == request.time;
    }

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin() || (signedIn() && isApproved());
      allow list: if isAdmin() ||
        (signedIn() && resource.data.status == 'approved' && resource.data.onboardingComplete == true);
      allow create: if isOwner(uid) &&
                      request.resource.data.keys().hasOnly(clientWritableUserFields()) &&
                      !request.resource.data.keys().hasAny(protectedUserFields());
      allow update: if isOwner(uid) &&
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedUserFields());
      allow delete: if false;
    }

    match /posts/{postId} {
      allow get, list: if signedIn();
      allow create: if signedIn() &&
                       request.resource.data.authorUid == request.auth.uid &&
                       request.resource.data.type in ['hiring', 'co-founder', 'paid-project', 'pressure-test', 'warm-intro'] &&
                       request.resource.data.title is string &&
                       request.resource.data.title.size() >= 5 &&
                       request.resource.data.title.size() <= 120 &&
                       request.resource.data.description is string &&
                       request.resource.data.description.size() >= 10;
      allow update: if signedIn() && resource.data.authorUid == request.auth.uid;
      allow delete: if (signedIn() && resource.data.authorUid == request.auth.uid) || isAdmin();
    }

    match /connections/{connectionId} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.viewerUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get, list: if signedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if isAdmin();
    }

    match /consent_records/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /pending_users/{uid} {
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow read: if isOwner(uid) || isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

  }
}
