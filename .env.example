# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# OPENAI_API_KEY: OpenAI API key for generating text embeddings (text-embedding-3-small).
# Used by /api/embed — called on profile save and post creation.
OPENAI_API_KEY="REPLACE_ME"

# RESEND_API_KEY: Resend API key for sending smart match notification emails.
# Used by /api/notify. Get yours at resend.com. Free tier: 100 emails/day.
RESEND_API_KEY="REPLACE_ME"

# RESEND_FROM_EMAIL: Verified sender address on Resend for outgoing notifications.
RESEND_FROM_EMAIL="REPLACE_ME"

# FIREBASE_SERVICE_ACCOUNT_JSON: JSON.stringify(...) output of your Firebase service account.
FIREBASE_SERVICE_ACCOUNT_JSON="REPLACE_ME"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=REPLACE_ME

# CRON_SECRET: Secret token to authenticate Vercel cron job requests.
# Set the same value in Vercel dashboard → Settings → Environment Variables.
# Generate one with: openssl rand -hex 32
CRON_SECRET=REPLACE_ME

# GROQ_API_KEY: Groq API key for the Civ RAG chatbot (llama-3.1-70b-versatile).
# Used by /api/chat. Get yours at console.groq.com.
GROQ_API_KEY=REPLACE_ME

# ─── SEED SCRIPT DEPENDENCIES ────────────────────────────────────────────────
# Before running `npx ts-node scripts/seed.ts`, install:
#   npm install --save-dev ts-node dotenv @types/node
# The seed script reads .env.local (not .env) for OPENAI_API_KEY.
# Copy this file to .env.local and fill in real values before seeding.
