# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000/"

# OPENAI_API_KEY: OpenAI API key for generating text embeddings (text-embedding-3-small).
# Used by /api/embed — called on profile save and post creation.
OPENAI_API_KEY="your_openai_api_key_here"

# RESEND_API_KEY: Resend API key for sending smart match notification emails.
# Used by /api/notify. Get yours at resend.com. Free tier: 100 emails/day.
RESEND_API_KEY="your_resend_api_key_here"

# RESEND_FROM_EMAIL: Verified sender address on Resend for outgoing notifications.
RESEND_FROM_EMAIL=""

# ADMIN_EMAILS: Comma-separated list of Google-authenticated email addresses
# that have access to the /app/admin panel (invite management, connection export).
ADMIN_EMAILS=""

# NEXT_PUBLIC_ADMIN_EMAILS: Same list, exposed to the client so the feed page
# can show the admin nav link to admin users. Keep in sync with ADMIN_EMAILS.
NEXT_PUBLIC_ADMIN_EMAILS=""

# ─── SEED SCRIPT DEPENDENCIES ────────────────────────────────────────────────
# Before running `npx ts-node scripts/seed.ts`, install:
#   npm install --save-dev ts-node dotenv @types/node
# The seed script reads .env.local (not .env) for OPENAI_API_KEY.
# Copy this file to .env.local and fill in real values before seeding.
